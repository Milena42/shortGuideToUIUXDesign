{
    "include": ["./examples/**/*", "./.vitepress/**/*", "./**/*.md", "*.md"],
    "exclude": ["./node_modules/**/*"],
    "vueCompilerOptions": {
        "vitePressExtensions": [".md"]
    },
    "compilerOptions": {
        "paths": {
            "/*": ["./*"]
        },
        "skipLibCheck": true
    }
}
